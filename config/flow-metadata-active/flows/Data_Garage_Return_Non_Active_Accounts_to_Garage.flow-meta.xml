            </connector>
            <label>Account has not been active</label>
        </rules>
    </decisions>
    <decisions>
        <name>X3_Month_Check</name>
        <label>3 Month Check</label>
        <locationX>1007</locationX>
        <locationY>252</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Over_3_Months_Old</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Reallocated_Time_Stamp__c</leftValueReference>
                <operator>LessThan</operator>
                <rightValue>
                    <elementReference>Three_Months_Formula</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_Opps</targetReference>
            </connector>
            <label>Over 3 Months Old</label>
        </rules>
    </decisions>
    <description>Schedule flow which checks the Reallocated Time Stamp on accounts. If no activity within 3 months it will return to the garage.</description>
    <environments>Default</environments>
    <formulas>
        <name>Three_Months_Formula</name>
        <dataType>Date</dataType>
        <expression>TODAY() - 90</expression>
    </formulas>
    <interviewLabel>Data Garage - Return Non-Active Accounts to Garage {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Data Garage - Return Non-Active Accounts to Garage</label>
