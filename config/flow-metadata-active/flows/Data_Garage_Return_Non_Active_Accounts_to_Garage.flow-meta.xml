                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.Data_Garage_Territory__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Scotland North</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Marino_as_Acc_Owner</targetReference>
            </connector>
            <label>Scotland</label>
        </rules>
    </decisions>
    <decisions>
        <name>Has_Account_Been_Active_since_Rellocation</name>
        <label>Has Account Been Active since Rellocation?</label>
        <locationX>732</locationX>
        <locationY>576</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Account_has_not_been_active</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>Get_Opps</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
