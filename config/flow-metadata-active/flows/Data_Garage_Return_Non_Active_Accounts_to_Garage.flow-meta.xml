    <decisions>
        <name>Check_Data_Garage_Territory</name>
        <label>Check Data Garage Territory</label>
        <locationX>446</locationX>
        <locationY>684</locationY>
        <defaultConnector>
            <targetReference>Update_Account_Owner</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>England</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Data_Garage_Territory__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>England</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_Marco_as_Acc_Owner</targetReference>
            </connector>
            <label>England</label>
        </rules>
        <rules>
            <name>Ireland</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Data_Garage_Territory__c</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Ireland</stringValue>
                </rightValue>
            </conditions>
            <connector>
