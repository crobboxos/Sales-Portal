    <collectionProcessors>
        <name>Location_Loop_Filter</name>
        <elementSubtype>FilterCollectionProcessor</elementSubtype>
        <label>Location Loop Filter</label>
        <locationX>264</locationX>
        <locationY>566</locationY>
        <assignNextValueToReference>currentItem_Location_Loop_Filter</assignNextValueToReference>
        <collectionProcessorType>FilterCollectionProcessor</collectionProcessorType>
        <collectionReference>Get_All_Locations</collectionReference>
        <conditionLogic>and</conditionLogic>
        <conditions>
            <leftValueReference>currentItem_Location_Loop_Filter.Site_Address__PostalCode__s</leftValueReference>
            <operator>EqualTo</operator>
            <rightValue>
                <elementReference>Location_Loop.Location_Address.postalCode</elementReference>
            </rightValue>
        </conditions>
        <connector>
            <targetReference>Assignment_1</targetReference>
        </connector>
    </collectionProcessors>
    <environments>Default</environments>
    <formulas>
        <name>CountryCode</name>
        <dataType>String</dataType>
        <expression>CASE({!Location_Loop.Location_Address.country}, 
&quot;United Kingdom&quot;, &quot;GB&quot;, 
&quot;Ireland&quot;, &quot;IE&quot;, 
&quot;GB&quot;)</expression>
    </formulas>
    <formulas>
        <name>Location_Name</name>
        <dataType>String</dataType>
        <expression>{!Get_Account.Name}+&quot; - &quot;+{!Location_Loop.Location_Address.postalCode}</expression>
    </formulas>
