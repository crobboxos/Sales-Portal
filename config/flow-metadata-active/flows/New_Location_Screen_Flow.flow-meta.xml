        <locationY>674</locationY>
        <assignmentItems>
            <assignToReference>Location_Singular.LocationType</assignToReference>
            <operator>Assign</operator>
            <value>
                <stringValue>Site</stringValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Location_Singular.Location_Account__c</assignToReference>
            <operator>Assign</operator>
