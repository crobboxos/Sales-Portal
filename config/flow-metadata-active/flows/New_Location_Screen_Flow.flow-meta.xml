        </assignmentItems>
        <assignmentItems>
            <assignToReference>Location_Singular.Site_Address__Street__s</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Location_Loop.Location_Address.street</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>Location_Singular.Name</assignToReference>
