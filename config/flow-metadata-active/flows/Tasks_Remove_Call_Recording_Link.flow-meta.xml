    <decisions>
        <name>Check_for_Call_Recording</name>
        <label>Check for Call Recording</label>
        <locationX>182</locationX>
        <locationY>323</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Contains_Call_Recording</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Description</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <stringValue>Call recording:</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Task_Comments</targetReference>
            </connector>
            <label>Contains Call Recording</label>
        </rules>
    </decisions>
    <environments>Default</environments>
    <formulas>
        <name>replacedText</name>
        <dataType>String</dataType>
        <expression>SUBSTITUTE({!$Record.Description}, 
           MID({!$Record.Description}, 
                    FIND(&quot;Call recording&quot;, {!$Record.Description}), 
                    LEN({!$Record.Description})
           ), 
&quot;&quot;)</expression>
    </formulas>
    <interviewLabel>Tasks - Remove Call Recording Link {!$Flow.CurrentDateTime}</interviewLabel>
    <label>Tasks - Remove Call Recording Link</label>
